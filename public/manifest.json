{
  "manifest_version": 3,
  "name": "Social Media Blocker",
  "description": "Blocks social media sites until you write why you need access.",
  "version": "0.1.0",
  "action": {
    "default_title": "Social Media Blocker",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "*://facebook.com/*",
    "*://*.facebook.com/*",
    "*://fb.com/*",
    "*://*.fb.com/*",
    "*://messenger.com/*",
    "*://*.messenger.com/*",
    "*://m.me/*",
    "*://*.m.me/*",
    "*://instagram.com/*",
    "*://*.instagram.com/*",
    "*://x.com/*",
    "*://*.x.com/*",
    "*://twitter.com/*",
    "*://*.twitter.com/*",
    "*://t.co/*",
    "*://*.t.co/*",
    "*://tiktok.com/*",
    "*://*.tiktok.com/*",
    "*://reddit.com/*",
    "*://*.reddit.com/*",
    "*://redd.it/*",
    "*://*.redd.it/*",
    "*://youtube.com/*",
    "*://*.youtube.com/*",
    "*://youtu.be/*",
    "*://*.youtu.be/*",
    "*://snapchat.com/*",
    "*://*.snapchat.com/*",
    "*://pinterest.com/*",
    "*://*.pinterest.com/*",
    "*://pin.it/*",
    "*://*.pin.it/*",
    "*://linkedin.com/*",
    "*://*.linkedin.com/*",
    "*://threads.net/*",
    "*://*.threads.net/*",
    "*://discord.com/*",
    "*://*.discord.com/*",
    "*://discord.gg/*",
    "*://*.discord.gg/*",
    "*://twitch.tv/*",
    "*://*.twitch.tv/*",
    "*://tumblr.com/*",
    "*://*.tumblr.com/*",
    "*://bsky.app/*",
    "*://*.bsky.app/*",
    "*://bsky.social/*",
    "*://*.bsky.social/*",
    "*://mastodon.social/*",
    "*://*.mastodon.social/*",
    "*://mastodon.online/*",
    "*://*.mastodon.online/*",
    "*://whatsapp.com/*",
    "*://*.whatsapp.com/*",
    "*://telegram.org/*",
    "*://*.telegram.org/*",
    "*://t.me/*",
    "*://*.t.me/*",
    "*://vk.com/*",
    "*://*.vk.com/*",
    "*://weibo.com/*",
    "*://*.weibo.com/*"
  ]
}
