{
  "manifest_version": 3,
  "name": "Social Media Blocker",
  "description": "Blocks social media and video streaming sites until you write why you need access.",
  "version": "0.1.1",
  "action": {
    "default_title": "Social Media Blocker",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "alarms"
  ],
  "host_permissions": [
    "*://facebook.com/*",
    "*://*.facebook.com/*",
    "*://fb.com/*",
    "*://*.fb.com/*",
    "*://messenger.com/*",
    "*://*.messenger.com/*",
    "*://m.me/*",
    "*://*.m.me/*",
    "*://instagram.com/*",
    "*://*.instagram.com/*",
    "*://x.com/*",
    "*://*.x.com/*",
    "*://twitter.com/*",
    "*://*.twitter.com/*",
    "*://t.co/*",
    "*://*.t.co/*",
    "*://tiktok.com/*",
    "*://*.tiktok.com/*",
    "*://reddit.com/*",
    "*://*.reddit.com/*",
    "*://redd.it/*",
    "*://*.redd.it/*",
    "*://youtube.com/*",
    "*://*.youtube.com/*",
    "*://youtu.be/*",
    "*://*.youtu.be/*",
    "*://snapchat.com/*",
    "*://*.snapchat.com/*",
    "*://pinterest.com/*",
    "*://*.pinterest.com/*",
    "*://pin.it/*",
    "*://*.pin.it/*",
    "*://linkedin.com/*",
    "*://*.linkedin.com/*",
    "*://threads.net/*",
    "*://*.threads.net/*",
    "*://discord.com/*",
    "*://*.discord.com/*",
    "*://discord.gg/*",
    "*://*.discord.gg/*",
    "*://twitch.tv/*",
    "*://*.twitch.tv/*",
    "*://tumblr.com/*",
    "*://*.tumblr.com/*",
    "*://bsky.app/*",
    "*://*.bsky.app/*",
    "*://bsky.social/*",
    "*://*.bsky.social/*",
    "*://mastodon.social/*",
    "*://*.mastodon.social/*",
    "*://mastodon.online/*",
    "*://*.mastodon.online/*",
    "*://whatsapp.com/*",
    "*://*.whatsapp.com/*",
    "*://telegram.org/*",
    "*://*.telegram.org/*",
    "*://t.me/*",
    "*://*.t.me/*",
    "*://vk.com/*",
    "*://*.vk.com/*",
    "*://weibo.com/*",
    "*://*.weibo.com/*",
    "*://netflix.com/*",
    "*://*.netflix.com/*",
    "*://hulu.com/*",
    "*://*.hulu.com/*",
    "*://disneyplus.com/*",
    "*://*.disneyplus.com/*",
    "*://max.com/*",
    "*://*.max.com/*",
    "*://hbomax.com/*",
    "*://*.hbomax.com/*",
    "*://primevideo.com/*",
    "*://*.primevideo.com/*",
    "*://tv.apple.com/*",
    "*://*.tv.apple.com/*",
    "*://paramountplus.com/*",
    "*://*.paramountplus.com/*",
    "*://peacocktv.com/*",
    "*://*.peacocktv.com/*",
    "*://crunchyroll.com/*",
    "*://*.crunchyroll.com/*",
    "*://tubitv.com/*",
    "*://*.tubitv.com/*",
    "*://pluto.tv/*",
    "*://*.pluto.tv/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
